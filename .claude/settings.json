{
  "$schema_comment": "Hooks que automatizan la verificación del harness (RF-CODE-001 / GU-HARNESS-001) y la activación de ponytail (ver docs/tooling.md). Los ejecuta el harness, no el agente, así que no se pueden saltar.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/ponytail/hooks/ponytail-activate.js\"",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PROJECT_DIR\\.claude\\ponytail\\hooks\\ponytail-activate.js\" }",
            "timeout": 5,
            "description": "ponytail: activa el modo (lazy senior dev) e inyecta su ruleset al iniciar la sesión."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/ponytail/hooks/ponytail-subagent.js\"",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PROJECT_DIR\\.claude\\ponytail\\hooks\\ponytail-subagent.js\" }",
            "timeout": 5,
            "description": "ponytail: propaga el ruleset a cada subagente (Task) porque no heredan el contexto de SessionStart."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/ponytail/hooks/ponytail-mode-tracker.js\"",
            "commandWindows": "if (Get-Command node -ErrorAction SilentlyContinue) { node \"$env:CLAUDE_PROJECT_DIR\\.claude\\ponytail\\hooks\\ponytail-mode-tracker.js\" }",
            "timeout": 5,
            "description": "ponytail: detecta /ponytail lite|full|ultra|off y 'stop ponytail' para cambiar el nivel activo."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm -s test 2>&1 | tail -6",
            "description": "Tras editar o escribir, corre la suite de tests y muestra el resumen."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./init.sh > /tmp/harness_init.log 2>&1 && echo '[harness] init.sh OK' || (echo '[harness] init.sh FALLO — revisa /tmp/harness_init.log' && tail -20 /tmp/harness_init.log)",
            "description": "Antes de cerrar la sesión, fuerza una verificación completa."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(./init.sh)",
      "Bash(bash ./init.sh)",
      "Bash(pnpm*)",
      "Bash(npx stryker*)",
      "Bash(node .claude/ponytail/hooks/*)"
    ]
  }
}
