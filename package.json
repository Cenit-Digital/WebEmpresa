{
  "name": "webempresa",
  "private": true,
  "version": "0.1.0",
  "description": "Web corporativa de Cénit Digital. Repositorio base del stack estándar de empresa (Vite + React + TypeScript + SCSS + pnpm + SSG).",
  "type": "module",
  "license": "UNLICENSED",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "dev:ssr": "vite-react-ssg dev",
    "build": "vite-react-ssg build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "mutation": "stryker run",
    "verify": "bash ./init.sh"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.0.0",
    "@fontsource/outfit": "^5.0.0",
    "@vercel/firewall": "^1.2.1",
    "autoskills": "^0.3.6",
    "radix-ui": "^1.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.30.0",
    "resend": "^6.17.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.4.0",
    "sass": "^1.80.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.46.0",
    "vite": "^7.3.0",
    "vite-react-ssg": "0.9.0",
    "vitest": "^4.0.0"
  }
}
