# .env.example — Variables de entorno de WebEmpresa (Cénit Digital)
#
# REGLA (RF-STACK-001): NINGUNA clave real se sube al repositorio.
# Copia este archivo a `.env.local`, rellena los valores y guárdalos también
# en el gestor de contraseñas del equipo y en las env vars de Vercel.
#
# Vite solo expone al cliente las variables con prefijo VITE_. El resto son
# de build/servidor y NUNCA deben llegar al bundle del navegador.

# ── Público (cliente, prefijo VITE_) ───────────────────────────────
VITE_SITE_URL=https://www.cenitdigital.es
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.posthog.com
VITE_SENTRY_DSN=

# ── Privado (build / serverless; NUNCA en el cliente) ──────────────
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RESEND_API_KEY=
# Destino y remitente del formulario de contacto (api/contact.ts). El remitente
# debe ser un dominio verificado en Resend. Si se omiten, se usan los valores por
# defecto (CONTACT_TO=hola@cenitdigital.es).
CONTACT_TO=
RESEND_FROM=
ANTHROPIC_API_KEY=
